{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "WebId": { "type": "string" },
          "Name": { "type": "string" },
          "Path": { "type": "string" },
          "UnitsAbbreviation": { "type": "string" },
          "Items": {
            "type": "array",
            "items": {
              "$ref": "timed-value.schema.json"
            }
          },
          "Value": {
            "anyOf": [
              { "$ref": "timed-value.schema.json" },
              { "type": "null" }
            ]
          }
        },
        "required": ["WebId", "Name"],
        "additionalProperties": true
      }
    }
  },
  "required": ["Items"],
  "additionalProperties": true
}
