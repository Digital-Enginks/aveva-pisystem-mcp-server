{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Timestamp": { "type": "string" },
    "Value": {
      "anyOf": [
        { "type": "number" },
        { "type": "string" },
        { "type": "null" },
        {
          "type": "object",
          "properties": {
            "Name": { "type": "string" },
            "Value": { "type": "integer" },
            "IsSystem": { "type": "boolean" }
          },
          "required": ["Name", "Value", "IsSystem"],
          "additionalProperties": false
        }
      ]
    },
    "UnitsAbbreviation": { "type": "string" },
    "Good": { "type": "boolean" },
    "Questionable": { "type": "boolean" },
    "Substituted": { "type": "boolean" },
    "Annotated": { "type": "boolean" }
  },
  "required": ["Timestamp", "Value", "Good"],
  "additionalProperties": true
}
