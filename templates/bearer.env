# ==============================================================================
# AVEVA PI System MCP Server - Environment Template: OIDC BEARER AUTHENTICATION
# ==============================================================================
# Use this file if your company uses AVEVA Identity Manager (AIM) or an OIDC
# token system to log into the PI System.
#
# INSTRUCTIONS:
# 1. Copy this file to a new file named '.env' in the root directory.
# 2. Fill in the values below.
# 3. Start the server.

# ------------------------------------------------------------------------------
# 1. Server Address & Mode
# ------------------------------------------------------------------------------
# The HTTPS address of your company's PI Web API server.
PIWEBAPI_BASE_URL=https://pi-web-api-server.company.com/piwebapi

# Select "stdio" (recommended for local use in Claude Desktop) or "http" (for network use).
MCP_TRANSPORT=stdio

# ------------------------------------------------------------------------------
# 2. Authentication Configuration
# ------------------------------------------------------------------------------
# We are choosing "bearer" mode to authenticate using web tokens.
PIWEBAPI_AUTH_MODE=bearer

# The address of your company's AVEVA Identity Manager (AIM) server.
# Must end with /identitymanager/
PIWEBAPI_BEARER_ISSUER=https://aim-server.company.com/identitymanager/

# The Client ID registered for this MCP server application on the AIM server.
PIWEBAPI_BEARER_CLIENT_ID=mcp-client-application-id

# Choose EXACTLY ONE secret provider (Value, File Path, or Environment variable name):
# 1. Direct Secret (easiest for testing)
PIWEBAPI_BEARER_CLIENT_SECRET=your-aim-client-secret-key
# 2. File Path (recommended for security)
# PIWEBAPI_BEARER_CLIENT_SECRET_FILE=C:\secrets\aim-secret.txt
# 3. Reference to another environment variable
# PIWEBAPI_BEARER_CLIENT_SECRET_REF=AIM_CLIENT_SECRET

# Target audience registered in the identity provider.
PIWEBAPI_BEARER_AUDIENCE=https://pi-web-api-server.company.com/piwebapi
PIWEBAPI_BEARER_GRANT=client_credentials

# ------------------------------------------------------------------------------
# 3. Security & Trust Settings
# ------------------------------------------------------------------------------
# Verify the certificates. Keep this as true.
PIWEBAPI_TLS_VERIFY=true

# If your company uses private certificates, supply the path to the Root CA certificate:
# PIWEBAPI_TLS_CA_FILE=C:\certs\company-root-ca.pem

# ------------------------------------------------------------------------------
# 4. Feature Settings
# ------------------------------------------------------------------------------
# The server is READ-ONLY by default. To allow the AI assistant to write data
# back to the PI System you must change BOTH settings below: set
# MCP_READ_ONLY=false AND MCP_WRITE_TOOLS_ENABLED=true. Changing only one of
# them makes the server refuse to start.
# Recommended for safety: keep both values as-is for read-only access.
MCP_READ_ONLY=true
MCP_WRITE_TOOLS_ENABLED=false

# Log detail level: debug (detailed) | info (normal) | warn (warnings) | error (errors)
MCP_LOG_LEVEL=info
