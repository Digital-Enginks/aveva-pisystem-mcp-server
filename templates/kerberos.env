# ==============================================================================
# AVEVA PI System MCP Server - Environment Template: KERBEROS AUTHENTICATION
# ==============================================================================
# Use this file if your company uses Active Directory (Windows accounts) to log
# into the PI System. This is the most common setup in industrial OT networks.
#
# INSTRUCTIONS:
# 1. Copy this file to a new file named '.env' in the root directory.
# 2. Fill in the values below.
# 3. Start the server.

# ------------------------------------------------------------------------------
# 1. Server Address & Mode
# ------------------------------------------------------------------------------
# The HTTPS address of your company's PI Web API server.
# Ask your PI Admin or IT team if you do not know this.
PIWEBAPI_BASE_URL=https://pi-web-api-server.company.com/piwebapi

# Select "stdio" (recommended for local use in Claude Desktop) or "http" (for network use).
MCP_TRANSPORT=stdio

# ------------------------------------------------------------------------------
# 2. Authentication Configuration
# ------------------------------------------------------------------------------
# We are choosing "kerberos" mode to log in with your Windows account.
PIWEBAPI_AUTH_MODE=kerberos

# The Service Principal Name (SPN) registered for the PI Web API.
# Usually, this is "HTTP/" followed by the domain name of the PI Web API server.
# If you get login errors, check with IT to see if the SPN is registered.
PIWEBAPI_KERBEROS_SPN=HTTP/pi-web-api-server.company.com

# ------------------------------------------------------------------------------
# 3. Security & Trust Settings
# ------------------------------------------------------------------------------
# Verify the PI Web API's certificate. Keep this as true.
PIWEBAPI_TLS_VERIFY=true

# If your company uses a private or internal security certificate for the PI Web API,
# save the certificate file (.pem format) on your computer and put the full path here:
# PIWEBAPI_TLS_CA_FILE=C:\certs\company-root-ca.pem

# ------------------------------------------------------------------------------
# 4. Feature Settings
# ------------------------------------------------------------------------------
# The server is READ-ONLY by default. To allow the AI assistant to write data
# back to the PI System you must change BOTH settings below: set
# MCP_READ_ONLY=false AND MCP_WRITE_TOOLS_ENABLED=true. Changing only one of
# them makes the server refuse to start.
# Recommended for safety: keep both values as-is for read-only access.
MCP_READ_ONLY=true
MCP_WRITE_TOOLS_ENABLED=false

# Log detail level: debug (detailed) | info (normal) | warn (warnings) | error (errors)
MCP_LOG_LEVEL=info
