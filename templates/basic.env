# ==============================================================================
# AVEVA PI System MCP Server - Environment Template: BASIC AUTHENTICATION
# ==============================================================================
# Use this file if you log into the PI System using a standard Username and Password.
# Note: Basic authentication should only be used as a last resort and over secure HTTPS.
#
# INSTRUCTIONS:
# 1. Copy this file to a new file named '.env' in the root directory.
# 2. Fill in the values below.
# 3. Start the server.

# ------------------------------------------------------------------------------
# 1. Server Address & Mode
# ------------------------------------------------------------------------------
# The HTTPS address of your company's PI Web API server.
PIWEBAPI_BASE_URL=https://pi-web-api-server.company.com/piwebapi

# Select "stdio" (recommended for local use in Claude Desktop) or "http" (for network use).
MCP_TRANSPORT=stdio

# ------------------------------------------------------------------------------
# 2. Authentication Configuration
# ------------------------------------------------------------------------------
# We are choosing "basic" mode to authenticate using standard credentials.
PIWEBAPI_AUTH_MODE=basic

# The username to log in with (include domain prefix if it is a domain account).
PIWEBAPI_BASIC_USER=company_domain\service-username

# Choose EXACTLY ONE password provider (Value, File Path, or Environment variable name):
# 1. Direct Password (easiest for testing)
PIWEBAPI_BASIC_PASSWORD=your-secret-account-password
# 2. File Path (recommended for security)
# PIWEBAPI_BASIC_PASSWORD_FILE=C:\secrets\pi-account-password.txt
# 3. Reference to another environment variable
# PIWEBAPI_BASIC_PASSWORD_REF=PI_ACCOUNT_PASSWORD

# ------------------------------------------------------------------------------
# 3. Security & Trust Settings
# ------------------------------------------------------------------------------
# Verify the certificates. Keep this as true.
PIWEBAPI_TLS_VERIFY=true

# If your company uses private certificates, supply the path to the Root CA certificate:
# PIWEBAPI_TLS_CA_FILE=C:\certs\company-root-ca.pem

# ------------------------------------------------------------------------------
# 4. Feature Settings
# ------------------------------------------------------------------------------
# The server is READ-ONLY by default. To allow the AI assistant to write data
# back to the PI System you must change BOTH settings below: set
# MCP_READ_ONLY=false AND MCP_WRITE_TOOLS_ENABLED=true. Changing only one of
# them makes the server refuse to start.
# Recommended for safety: keep both values as-is for read-only access.
MCP_READ_ONLY=true
MCP_WRITE_TOOLS_ENABLED=false

# Log detail level: debug (detailed) | info (normal) | warn (warnings) | error (errors)
MCP_LOG_LEVEL=info
