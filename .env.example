# ==============================================================================
# AVEVA PI System MCP Server - Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' and populate the required variables.
# For security details, refer to THREAT_MODEL.md and COMPATIBILITY.md.

# ------------------------------------------------------------------------------
# 1. Core Settings (Common to all modes)
# ------------------------------------------------------------------------------
# The base URL of the PI Web API instance. Must use HTTPS and end with /piwebapi.
PIWEBAPI_BASE_URL=https://pi-server.your-domain.com/piwebapi

# Transport mode: stdio (default for local clients) or http (for network clients)
MCP_TRANSPORT=stdio

# Binding settings if MCP_TRANSPORT=http
# MCP_HTTP_BIND=127.0.0.1
# MCP_HTTP_PORT=3000

# ------------------------------------------------------------------------------
# 2. Outbound Authentication Mode (Server ↔ PI Web API)
# ------------------------------------------------------------------------------
# Select exactly one mode: kerberos | bearer | basic | anonymous
PIWEBAPI_AUTH_MODE=kerberos

# ==============================================================================
# AUTH OPTION A: Kerberos (Negotiate) - MANDATED DEFAULT FOR ACTIVE DIRECTORY
# ==============================================================================
# Required if PIWEBAPI_AUTH_MODE=kerberos
# The Service Principal Name of the PI Web API service. Must start with HTTP/
PIWEBAPI_KERBEROS_SPN=HTTP/pi-server.your-domain.com

# Optional: Path to custom krb5.conf file or client keytab (if using headless authentication)
# KRB5_CONFIG=C:\etc\krb5.conf
# KRB5_CLIENT_KTNAME=C:\etc\mcp-service.keytab

# ==============================================================================
# AUTH OPTION B: Bearer (OAuth 2.0 via AVEVA Identity Manager)
# ==============================================================================
# Required if PIWEBAPI_AUTH_MODE=bearer
# Issuer URL of the AVEVA Identity Manager (AIM) or OIDC server. Cannot be sentinels.
# PIWEBAPI_BEARER_ISSUER=https://aim-server.your-domain.com/identitymanager/
# PIWEBAPI_BEARER_CLIENT_ID=mcp-client-id

# Choose EXACTLY ONE secret provider (Direct value, FILE path, or environment REF):
# PIWEBAPI_BEARER_CLIENT_SECRET=aim-client-secret-key-value
# PIWEBAPI_BEARER_CLIENT_SECRET_FILE=C:\secrets\aim-secret.txt
# PIWEBAPI_BEARER_CLIENT_SECRET_REF=MY_ORGANIZATION_AIM_SECRET_ENV_VAR

# Scope and Audience:
# PIWEBAPI_BEARER_SCOPE=openid email profile
# PIWEBAPI_BEARER_AUDIENCE=https://pi-server.your-domain.com/piwebapi
# PIWEBAPI_BEARER_GRANT=client_credentials

# ==============================================================================
# AUTH OPTION C: Basic Authentication - LAST RESORT (ONLY OVER SECURE TLS)
# ==============================================================================
# Required if PIWEBAPI_AUTH_MODE=basic
# PIWEBAPI_BASIC_USER=domain\service-username

# Choose EXACTLY ONE password provider (Direct value, FILE path, or environment REF):
# PIWEBAPI_BASIC_PASSWORD=my-clear-text-password-here
# PIWEBAPI_BASIC_PASSWORD_FILE=C:\secrets\pi-password.txt
# PIWEBAPI_BASIC_PASSWORD_REF=MY_ORGANIZATION_PI_PASSWORD_ENV_VAR

# ==============================================================================
# AUTH OPTION D: Anonymous Access - NOT RECOMMENDED FOR PRODUCTION
# ==============================================================================
# Set to true only if anonymous access is permitted on the PI Web API server.
PIWEBAPI_ALLOW_ANONYMOUS=false

# ------------------------------------------------------------------------------
# 3. TLS / Outbound Trust Settings
# ------------------------------------------------------------------------------
# Set to true to enforce certificate verification (Highly Recommended)
PIWEBAPI_TLS_VERIFY=true

# Path to the CA cert bundle (PEM format) if using a private or internal CA
# PIWEBAPI_TLS_CA_FILE=C:\certs\internal-ca-root.pem

# Minimum TLS protocol allowed. Default is TLSv1.2.
# PIWEBAPI_TLS_MIN_VERSION=TLSv1.2

# Optional: SHA-256 certificate fingerprint pinning to lock down trust
# PIWEBAPI_TLS_PIN_SHA256=1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b

# Optional: Client certificates for mTLS outbound validation
# PIWEBAPI_CLIENT_CERT_FILE=C:\certs\mcp-client.pem
# PIWEBAPI_CLIENT_CERT_KEY_FILE=C:\certs\mcp-client-key.pem

# ------------------------------------------------------------------------------
# 4. Inbound Edge Security (Only used if MCP_TRANSPORT=http)
# ------------------------------------------------------------------------------
# Inbound authentication mode at the network edge: bearer | mtls | none
# MCP_EDGE_AUTH_MODE=none

# If using edge bearer token validation:
# MCP_EDGE_JWKS_URL=https://auth-server.your-domain.com/.well-known/jwks.json
# MCP_EDGE_AUDIENCE=urn:mcp-server
# Expected token issuer; when set, tokens from any other issuer are rejected (recommended for public deployments):
# MCP_EDGE_ISSUER=https://auth-server.your-domain.com/

# If using edge mTLS client certificate verification:
# MCP_EDGE_MTLS_CA_FILE=C:\certs\trusted-client-cas.pem
# Roles granted to an authenticated mTLS client. Defaults to read-only; set to read,write to allow writes over mTLS:
# MCP_EDGE_MTLS_ROLES=read

# Role validation for write tools:
# MCP_EDGE_WRITE_ROLES=mcp-write-operators,mcp-admins
# MCP_EDGE_RATE_LIMIT=100

# ------------------------------------------------------------------------------
# 5. Upstream Limits, Timeouts & Caching
# ------------------------------------------------------------------------------
PIWEBAPI_REQUEST_TIMEOUT_MS=10000
# PIWEBAPI_MAX_CONCURRENT=50
# PIWEBAPI_WEBID_CACHE_TTL_SEC=300
# PIWEBAPI_META_CACHE_TTL_SEC=300

# ------------------------------------------------------------------------------
# 6. Feature Flags
# ------------------------------------------------------------------------------
# The server is read-only by default. To enable write-capable tools you must
# set BOTH MCP_READ_ONLY=false AND MCP_WRITE_TOOLS_ENABLED=true; changing only
# one of them makes the server refuse to start.
MCP_READ_ONLY=true
MCP_WRITE_TOOLS_ENABLED=false

# Level of logging: debug | info | warn | error
MCP_LOG_LEVEL=info
