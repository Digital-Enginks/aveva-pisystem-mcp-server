{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "feat",
        "fix",
        "perf",
        "docs",
        "refactor",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "scope-enum": [
      2,
      "always",
      [
        "protocol",
        "tools",
        "gateway",
        "auth",
        "security",
        "config",
        "errors",
        "docs",
        "ci",
        "release"
      ]
    ],
    "scope-empty": [1, "never"]
  }
}
